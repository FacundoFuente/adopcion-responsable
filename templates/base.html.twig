<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Adopción Responsable{% endblock %}</title>
        <link rel="icon" type="image/svg+xml" href="{{ asset('images/logo.svg') }}">
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body class="{% block body_class %}{% endblock %}">
        <header class="navbar navbar-expand bg-white border-bottom shadow-sm app-header">
            <div class="container-fluid h-100 px-4 d-flex align-items-center justify-content-between">
                <a href="{{ path('homepage') }}" class="app-header-brand" aria-label="Ir al inicio">
                    <img src="{{ asset('images/logo.svg') }}" alt="Adopción Responsable" class="app-header-logo">
                </a>

                <div
                    class="app-header-banner-wrap"
                    aria-label="Banner principal"
                >
                    <img
                        src="{{ asset('images/header.png') }}"
                        alt="Perdidos en la Ciudad"
                        class="app-header-banner"
                    >
                </div>

                <div class="h-100 d-flex justify-content-end align-items-center gap-3 app-header-actions">
                    {% if app.user %}
                        <a href="{{ path('app_my_records') }}" class="btn btn-outline-primary btn-sm">Mis prontuarios</a>
                        <div class="d-flex align-items-center text-muted app-header-user-info">
                            <span class="me-2" aria-hidden="true">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                                    <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                                </svg>
                            </span>
                            <span class="fw-semibold app-header-user-email">{{ app.user.email }}</span>
                        </div>
                        <a href="{{ path('app_sign_out') }}" class="btn btn-outline-danger btn-sm">Logout</a>
                    {% else %}
                        <a href="{{ path('app_sign_in') }}" class="btn btn-primary btn-sm">Ingresar</a>
                    {% endif %}
                </div>
            </div>
        </header>
        {% block body %}{% endblock %}

        {% if app.request.attributes.get('_route') == 'homepage' and app.request.query.get('dni') is empty %}
            <a
                id="mobileVideoFooter"
                href="https://perdidosenlaciudad.com.ar"
                target="_blank"
                rel="noopener noreferrer"
                class="app-mobile-video-footer"
                aria-label="Ir a perdidosenlaciudad.com.ar"
            >
                <video class="app-mobile-video-footer-media" autoplay muted loop playsinline preload="metadata">
                    <source src="{{ asset('videos/video.mp4') }}" type="video/mp4">
                </video>
            </a>
        {% endif %}
    </body>
</html>
