{% extends 'base.html.twig' %}

{% block title %}Registarse{% endblock %}

{% block body %}
<div class="container py-4 py-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-sm-10 col-md-8 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <h1 class="h3 text-center mb-4">REGISTRARSE</h1>
                    {{ form_start(registrationForm) }}
                        {% set emailError = registrationForm.email.vars.errors|length > 0 ? registrationForm.email.vars.errors|first.message : '' %}
                        {% set passwordError = registrationForm.plainPassword.vars.errors|length > 0 ? registrationForm.plainPassword.vars.errors|first.message : '' %}
                        {% if return_to %}
                            <input type="hidden" name="return_to" value="{{ return_to }}">
                        {% endif %}
                        <div class="mb-3">
                            {{ form_label(registrationForm.email, 'Email', { label_attr: { class: 'form-label' } }) }}
                            {{ form_widget(registrationForm.email, { attr: { class: 'form-control', placeholder: 'Email', 'data-server-error': emailError } }) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword, 'Clave', { label_attr: { class: 'form-label' } }) }}
                            {{ form_widget(registrationForm.plainPassword, { attr: { class: 'form-control', placeholder: 'Clave', 'data-server-error': passwordError } }) }}
                        </div>

                        <div class="form-check mb-2 d-flex align-items-center text-start">
                            {{ form_widget(registrationForm.agreeTerms, {
                                attr: { class: 'form-check-input me-2' }
                            }) }}
                            <label for="{{ registrationForm.agreeTerms.vars.id }}" class="form-check-label mt-1">
                                Acepto los
                                <a href="{{ path('app_terms') }}" target="_blank" class="ms-1 text-decoration-underline">
                                    términos y condiciones
                                </a>
                            </label>
                        </div>
                        {{ form_errors(registrationForm.agreeTerms) }}

                        {% if form_errors(registrationForm) %}
                            <div class="alert alert-danger py-2 mb-3">
                                {{ form_errors(registrationForm) }}
                            </div>
                        {% endif %}

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">REGISTRARME</button>
                        </div>
                    {{ form_end(registrationForm) }}

                    <p class="mb-0 text-center">
                        Si tenes cuenta, podes identificarte <a href="{{ return_to ? path('app_sign_in', { return_to: return_to }) : path('app_sign_in') }}">aquí</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const inputs = document.querySelectorAll('[data-server-error]');
        let firstInvalid = null;

        inputs.forEach((input) => {
            const message = String(input.dataset.serverError || '').trim();
            if (!message) {
                return;
            }

            input.setCustomValidity(message);
            input.addEventListener('input', function () {
                input.setCustomValidity('');
            }, { once: true });

            if (!firstInvalid) {
                firstInvalid = input;
            }
        });

        if (firstInvalid) {
            firstInvalid.focus();
            firstInvalid.reportValidity();
        }
    });
</script>
{% endblock %}
